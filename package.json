{
  "name": "kocteau",
  "private": true,
  "packageManager": "pnpm@9.15.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile run start",
    "dev:mobile:tunnel": "pnpm --filter mobile run start:tunnel",
    "dev:mobile:clear": "pnpm --filter mobile run start:clear",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "2.9.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
