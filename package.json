{
  "name": "kocteau",
  "version": "0.1.3",
  "private": true,
  "packageManager": "pnpm@9.15.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile run start",
    "dev:mobile:tunnel": "pnpm --filter mobile run start:tunnel",
    "dev:mobile:clear": "pnpm --filter mobile run start:clear",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check": "pnpm lint && pnpm --filter web build",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -o CHANGELOG.md -r 0 --output-unreleased --commit-path apps/web",
    "changelog:preview": "conventional-changelog -p conventionalcommits -r 0 --output-unreleased --commit-path apps/web --stdout"
  },
  "devDependencies": {
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "turbo": "2.9.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "tar": "7.5.11",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
