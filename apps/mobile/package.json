{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --lan --port 8082",
    "start:lan": "expo start --lan --port 8082",
    "start:tunnel": "expo start --tunnel --port 8082",
    "start:clear": "expo start --lan --port 8082 --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/react"
      ]
    }
  },
  "dependencies": {
    "@kocteau/config": "workspace:*",
    "@kocteau/types": "workspace:*",
    "@tanstack/react-query": "^5.100.9",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/elements": "^2.9.15",
    "@react-navigation/native": "^7.1.8",
    "expo": "~55.0.20",
    "expo-constants": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.85.2",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-worklets": "0.8.3",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0"
  },
  "private": true
